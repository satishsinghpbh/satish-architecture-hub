<mxfile host="app.diagrams.net" modified="2024-01-01T00:00:00.000Z" agent="draw.io" version="21.1.2" type="device"><diagram id="1._Upload_Flow" name="1. Upload Flow">&lt;mxGraphModel background="#1a1f2e" dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0"&gt;&lt;root&gt;&lt;mxCell id="0" /&gt;&lt;mxCell id="1" parent="0" /&gt;&lt;mxCell id="2" value="Trade File Architecture — DB Save + IBM MQ (Single @Transactional · Non-XA)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#38bdf8;fontSize=18;fontStyle=3;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="20" width="900" height="40" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="3" value="PHASE 1 — UPLOAD : Happy Path" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#38bdf8;fontSize=12;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="75" width="1100" height="30" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="4" value="🖥 Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#38bdf8;strokeWidth=2;fontColor=#e2e8f0;fontSize=11;fontStyle=1;;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="130" width="130" height="70" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="5" value="POST /upload&amp;#10;file + userId&amp;#10;+ correlationId ①" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="45" y="175" width="120" height="50" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="6" value="Controller" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#38bdf8;strokeWidth=2;fontColor=#e2e8f0;fontSize=11;fontStyle=1;;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="240" y="130" width="145" height="70" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="7" value="validates input&amp;#10;delegates to service" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="245" y="175" width="135" height="45" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="8" value="@Transactional — JPA local tx only (TradeFileService.uploadFile())" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=2;dashed=1;fontSize=9;fontColor=#34d399;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="455" y="95" width="320" height="240" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="9" value="① Idempotency Check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#2dd4bf;strokeWidth=2;fontColor=#2dd4bf;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="470" y="130" width="285" height="55" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="10" value="SELECT by correlationId&amp;#10;if found → return existing fileId" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="475" y="155" width="275" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="11" value="② fileRepo.save()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#34d399;strokeWidth=2;fontColor=#34d399;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="470" y="198" width="285" height="55" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="12" value="status = SUBMITTED · returns fileId&amp;#10;written but NOT committed yet" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="475" y="222" width="275" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="13" value="③ jmsTemplate.send() 📨" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#fbbf24;strokeWidth=2;fontColor=#fbbf24;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="470" y="266" width="285" height="55" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="14" value="fileId + userId → IBM MQ&amp;#10;fires INSIDE open transaction" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="475" y="290" width="275" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="15" value="↓ method returns → JPA COMMITS DB" style="text;html=1;strokeColor=none;fillColor=none;fontColor=#34d399;fontSize=9;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="470" y="325" width="270" height="18" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="16" value="HTTP 200&amp;#10;return fileId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#38bdf8;strokeWidth=2;fontColor=#e2e8f0;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="845" y="155" width="130" height="70" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="17" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#38bdf8;strokeWidth=2;fontColor=#94a3b8;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="4" target="6" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="18" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#38bdf8;strokeWidth=2;fontColor=#94a3b8;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="6" target="8" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="19" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#38bdf8;strokeWidth=2;fontColor=#94a3b8;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="8" target="16" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="20" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#34d399;strokeWidth=2;fontColor=#94a3b8;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="9" target="11" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="21" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#34d399;strokeWidth=2;fontColor=#94a3b8;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="11" target="13" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="22" value="⚡ MQ send() throws RuntimeException → @Transactional rolls back DB automatically. No orphan record. Client gets error and can retry." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;fontColor=#94a3b8;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="365" width="935" height="40" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="23" value="THE TWO UPLOAD GAPS" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#38bdf8;fontSize=12;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="430" width="935" height="28" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="24" value="GAP 1 — DB Commit Fails After MQ Send" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=2;dashed=1;fontSize=9;fontColor=#f87171;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="475" width="450" height="240" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="25" value="MQ send() succeeds inside @Transactional.&amp;#10;JPA goes to commit → DB throws (timeout / deadlock).&amp;#10;DB rolls back — but MQ message already sent." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="50" y="510" width="430" height="55" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="26" value="save() ✅" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#34d399;strokeWidth=2;fontColor=#34d399;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="55" y="575" width="90" height="50" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="27" value="send() ✅" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#fbbf24;strokeWidth=2;fontColor=#fbbf24;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="185" y="575" width="90" height="50" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="28" value="commit ❌&amp;#10;DB rolls back" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#f87171;strokeWidth=2;fontColor=#f87171;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="315" y="575" width="120" height="50" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="29" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#34d399;strokeWidth=2;fontColor=#94a3b8;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="26" target="27" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="30" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#f87171;strokeWidth=2;fontColor=#f87171;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="27" target="28" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="31" value="⚠ Listener gets fileId → DB has no record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=1;dashed=1;fontColor=#f87171;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="50" y="640" width="420" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="32" value="🛡 fetchWithRetry 5x → exhausted → trade_file_dlq (REQUIRES_NEW tx)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;dashed=1;fontColor=#34d399;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="50" y="680" width="420" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="33" value="GAP 2 — Race: Listener Faster Than DB Commit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#181008;strokeColor=#fbbf24;strokeWidth=2;dashed=1;fontSize=9;fontColor=#fbbf24;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="525" y="475" width="450" height="240" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="34" value="MQ send() fires inside open @Transactional.&amp;#10;IBM MQ fast consumer picks message before&amp;#10;JPA commits the trade_file row." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="535" y="510" width="430" height="55" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="35" value="save() ✅&amp;#10;uncommitted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#34d399;strokeWidth=2;fontColor=#34d399;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="540" y="575" width="100" height="50" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="36" value="send() ✅&amp;#10;MQ fast" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#fbbf24;strokeWidth=2;fontColor=#fbbf24;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="680" y="575" width="100" height="50" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="37" value="Listener&amp;#10;NOT FOUND" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#f87171;strokeWidth=2;fontColor=#f87171;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="820" y="575" width="110" height="50" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="38" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#fbbf24;strokeWidth=2;fontColor=#fbbf24;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="35" target="36" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="39" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#f87171;strokeWidth=2;fontColor=#f87171;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="36" target="37" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="40" value="⚠ DB commit still in flight — listener sees empty result" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=1;dashed=1;fontColor=#f87171;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="535" y="640" width="420" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="41" value="🛡 fetchWithRetry attempt #2 after 500ms — DB committed by then" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;dashed=1;fontColor=#34d399;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="535" y="680" width="420" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="42" value="① CLIENT IDEMPOTENCY KEY — Critical Addition" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#38bdf8;fontSize=12;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="745" width="935" height="28" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="43" value="⚠ Client upload times out → client retries → two trade_file rows → two MQ messages → file processed TWICE (retry storm)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=1;dashed=1;fontColor=#f87171;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="785" width="450" height="55" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="44" value="🛡 Client sends unique correlationId per upload. DB has UNIQUE(correlation_id). Second upload hits idempotency check → returns existing fileId. No duplicate record or message." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;dashed=1;fontColor=#34d399;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="510" y="785" width="465" height="55" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="45" value="ALTER TABLE trade_file ADD COLUMN correlation_id VARCHAR(100);&amp;#10;ALTER TABLE trade_file ADD CONSTRAINT uq_corr UNIQUE (correlation_id);" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#060a10;strokeColor=#2dd4bf;strokeWidth=1;fontColor=#2dd4bf;fontSize=10;fontFamily=3;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="850" width="935" height="45" as="geometry" /&gt;&lt;/mxCell&gt;&lt;/root&gt;&lt;/mxGraphModel&gt;</diagram><diagram id="2._Listener_Flow" name="2. Listener Flow">&lt;mxGraphModel background="#1a1f2e" dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0"&gt;&lt;root&gt;&lt;mxCell id="0" /&gt;&lt;mxCell id="1" parent="0" /&gt;&lt;mxCell id="2" value="Trade File Architecture — IBM MQ Listener Flow" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#38bdf8;fontSize=18;fontStyle=3;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="20" width="900" height="40" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="3" value="CRITICAL IMPLEMENTATION TRAPS — MUST GET RIGHT" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#38bdf8;fontSize=12;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="75" width="1250" height="28" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="4" value="② Spring AOP Self-Invocation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=2;dashed=1;fontSize=9;fontColor=#f87171;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="115" width="395" height="140" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="5" value="⚠ onMessage() calls processFile() in SAME class → @Transactional proxy bypassed → NO TRANSACTION at all." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=1;dashed=1;fontColor=#f87171;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="55" y="148" width="368" height="45" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="6" value="🛡 processFile() must be in a SEPARATE @Service (TradeFileProcessorService). Spring proxy only intercepts calls via injected bean." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;dashed=1;fontColor=#34d399;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="55" y="198" width="368" height="45" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="7" value="③ fetchWithRetry Isolation Trap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=2;dashed=1;fontSize=9;fontColor=#f87171;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="455" y="115" width="395" height="140" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="8" value="⚠ If fetchWithRetry() is INSIDE @Transactional, REPEATABLE_READ caches the first empty result. Every retry returns empty forever." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=1;dashed=1;fontColor=#f87171;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="470" y="148" width="368" height="45" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="9" value="🛡 Call fetchWithRetry() BEFORE any @Transactional boundary. Each attempt is a fresh independent DB read." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;dashed=1;fontColor=#34d399;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="470" y="198" width="368" height="45" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="10" value="④ markInProgress Propagation Trap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=2;dashed=1;fontSize=9;fontColor=#f87171;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="870" y="115" width="425" height="140" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="11" value="⚠ If markInProgress uses REQUIRES_NEW it commits independently. App crash mid-row → status stuck IN_PROGRESS forever, file never retried." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=1;dashed=1;fontColor=#f87171;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="885" y="148" width="395" height="45" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="12" value="🛡 Use default REQUIRES propagation → joins parent tx → rolls back together on failure → status reverts to SUBMITTED automatically." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;dashed=1;fontColor=#34d399;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="885" y="198" width="395" height="45" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="13" value="LISTENER STEPS (CLIENT_ACKNOWLEDGE — message NOT acked until Step 5)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#38bdf8;fontSize=12;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="275" width="1290" height="28" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="14" value="① Message Arrives" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#c084fc;strokeWidth=2;fontColor=#c084fc;fontSize=11;fontStyle=1;;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="320" width="175" height="130" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="15" value="CLIENT_ACKNOWLEDGE&amp;#10;message NOT acked yet&amp;#10;fileId + userId received" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="48" y="350" width="163" height="85" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="16" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#c084fc;strokeWidth=2;fontColor=#c084fc;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="14" target="17" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="17" value="② fetchWithRetry() ③" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#181008;strokeColor=#fbbf24;strokeWidth=2;dashed=1;fontSize=9;fontColor=#fbbf24;fontStyle=1;verticalAlign=top;;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="255" y="320" width="245" height="130" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="18" value="OUTSIDE @Transactional&amp;#10;Fresh read each attempt&amp;#10;#1: 0ms  #2: 500ms&amp;#10;#3: 1s   #4: 2s   #5: 4s" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="262" y="345" width="230" height="80" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="19" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#c084fc;strokeWidth=2;fontColor=#c084fc;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="17" target="20" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="20" value="③ Atomic Lock (1 SQL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=2;dashed=1;fontSize=9;fontColor=#f87171;fontStyle=1;verticalAlign=top;;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="545" y="320" width="290" height="130" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="21" value="UPDATE trade_file&amp;#10;SET status='IN_PROGRESS'&amp;#10;WHERE id=? AND status='SUBMITTED'&amp;#10;→ 1 row: proceed  /  0 rows: skip+ACK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#060a10;strokeColor=#f87171;strokeWidth=1;fontColor=#f87171;fontSize=10;fontFamily=3;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="558" y="348" width="264" height="80" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="22" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#c084fc;strokeWidth=2;fontColor=#c084fc;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="20" target="23" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="23" value="④ @Transactional(REQUIRES) — TradeFileProcessorService ④" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=2;dashed=1;fontSize=9;fontColor=#34d399;fontStyle=1;verticalAlign=top;;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="885" y="320" width="430" height="130" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="24" value="Read file content  →  Parse CSV&amp;#10;INSERT trade_instruction per row&amp;#10;  UNIQUE(file_id,row_num) → dup → skip&amp;#10;SET status = COMPLETED&amp;#10;← DB COMMITS HERE&amp;#10;  markInProgress JOINS this tx → rolls back together" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="895" y="348" width="410" height="90" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="25" value="⑤ acknowledgeWithRetry()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#120818;strokeColor=#c084fc;strokeWidth=2;dashed=1;fontSize=9;fontColor=#c084fc;fontStyle=1;verticalAlign=top;;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="255" y="475" width="245" height="120" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="26" value="3 attempts:&amp;#10;  Attempt 1: immediate&amp;#10;  Attempt 2: 500ms&amp;#10;  Attempt 3: 1000ms&amp;#10;ACK ok → message removed ✅" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="263" y="500" width="228" height="80" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="27" value="⑥ DLQ Path (fetch exhausted → Gap 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=2;dashed=1;fontSize=9;fontColor=#f87171;fontStyle=1;verticalAlign=top;;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="545" y="475" width="770" height="120" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="28" value="@Transactional(REQUIRES_NEW) — fully independent tx, always commits" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="556" y="500" width="440" height="20" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="29" value="INSERT trade_file_dlq" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#f87171;strokeWidth=2;fontColor=#f87171;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="556" y="525" width="195" height="55" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="30" value="fileId·userId·reason&amp;#10;rawMessage·status=PENDING" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="560" y="545" width="187" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="31" value="ACK message&amp;#10;(remove from IBM MQ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#f87171;strokeWidth=2;fontColor=#f87171;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="760" y="525" width="165" height="55" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="32" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#f87171;strokeWidth=2;fontColor=#f87171;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="29" target="31" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="33" value="👤 Ops Review&amp;#10;inspect DLQ table&amp;#10;re-upload &amp;amp; reprocess" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#fbbf24;strokeWidth=2;fontColor=#fbbf24;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="940" y="525" width="165" height="55" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="34" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#fbbf24;strokeWidth=2;fontColor=#fbbf24;fontSize=10;exitX=1;exitY=0.5;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="31" target="33" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="35" value="If ALL 3 ACKs fail → IBM MQ redelivers → status=COMPLETED → Step ③ returns 0 rows → SKIP + ACK. Safe infinite loop. Data integrity preserved." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;fontColor=#94a3b8;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="620" width="1290" height="40" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="36" value="⑤ IBM MQ BACKOUT QUEUE — Permanent Failure Path (corrupt file / always-throws)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#38bdf8;fontSize=12;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="680" width="1290" height="28" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="37" value="⚠ Corrupt file → parseCsv() always throws → listener nacks → IBM MQ redelivers → INFINITE LOOP without backout config." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=1;dashed=1;fontColor=#f87171;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="720" width="500" height="50" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="38" value="🛡 Configure IBM MQ BackoutThreshold=5. After 5 failed redeliveries → auto-moved to TRADE.FILE.BACKOUT queue → BackoutQueueListener → status=FAILED." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;dashed=1;fontColor=#34d399;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="778" width="500" height="50" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="39" value="DEFINE QLOCAL(TRADE.FILE.QUEUE)&amp;#10;  BOQNAME(TRADE.FILE.BACKOUT)&amp;#10;  BOTHRESH(5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#060a10;strokeColor=#f472b6;strokeWidth=1;fontColor=#f472b6;fontSize=10;fontFamily=3;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="555" y="720" width="340" height="55" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="40" value="TRADE.FILE.BACKOUT&amp;#10;(IBM MQ auto-populates)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#f472b6;strokeWidth=2;fontColor=#f472b6;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="915" y="720" width="190" height="55" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="41" value="BackoutQueueListener&amp;#10;@JmsListener" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#f472b6;strokeWidth=2;fontColor=#f472b6;fontSize=11;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="1120" y="720" width="185" height="55" as="geometry" /&gt;&lt;/mxCell&gt