EdgeStyle;html=1;strokeColor=#34d399;strokeWidth=2;fontColor=#34d399;fontSize=10;" edge="1" source="23" target="25" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="49" value="exhausted ❌" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#f87171;strokeWidth=2;fontColor=#f87171;fontSize=10;exitX=0.5;exitY=1;exitPerimeter=0;entryX=0;entryY=0.5;entryPerimeter=0;" edge="1" source="17" target="27" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;/root&gt;&lt;/mxGraphModel&gt;</diagram><diagram id="3._State_Machine" name="3. State Machine">&lt;mxGraphModel background="#1a1f2e" dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0"&gt;&lt;root&gt;&lt;mxCell id="0" /&gt;&lt;mxCell id="1" parent="0" /&gt;&lt;mxCell id="2" value="Trade File Architecture — Status State Machine &amp;amp;amp; Corner Cases" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#38bdf8;fontSize=18;fontStyle=3;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="20" width="1000" height="40" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="3" value="trade_file STATUS STATE MACHINE" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#38bdf8;fontSize=12;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="75" width="650" height="28" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="4" value="SUBMITTED&amp;#10;(set on upload DB commit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#34d399;strokeWidth=3;fontColor=#34d399;fontSize=14;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="260" y="120" width="230" height="70" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="5" value="IN_PROGRESS&amp;#10;(listener atomic lock wins)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#fbbf24;strokeWidth=3;fontColor=#fbbf24;fontSize=14;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="110" y="280" width="230" height="70" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="6" value="⚠ tx rolls back → reverts to SUBMITTED ④" style="text;html=1;strokeColor=none;fillColor=none;fontColor=#f87171;fontSize=9;align=center;" vertex="1" parent="1"&gt;&lt;mxGeometry x="60" y="355" width="330" height="18" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="7" value="trade_file_dlq&amp;#10;(5 fetch retries exhausted)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#f87171;strokeWidth=3;fontColor=#f87171;fontSize=14;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="440" y="280" width="230" height="70" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="8" value="status=PENDING → REPROCESSED&amp;#10;by ops after investigation" style="text;html=1;strokeColor=none;fillColor=none;fontColor=#94a3b8;fontSize=9;align=center;" vertex="1" parent="1"&gt;&lt;mxGeometry x="420" y="355" width="270" height="18" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="9" value="✅  COMPLETED&amp;#10;(terminal — all rows created)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#34d399;strokeWidth=3;fontColor=#34d399;fontSize=14;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="80" y="450" width="230" height="70" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="10" value="❌  FAILED&amp;#10;(permanent — IBM MQ backout ⑤)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#f472b6;strokeWidth=3;fontColor=#f472b6;fontSize=14;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="390" y="450" width="230" height="70" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="11" value="Atomic UPDATE&amp;#10;WHERE SUBMITTED" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#c084fc;strokeWidth=2;fontColor=#c084fc;fontSize=10;exitX=0.5;exitY=1;exitPerimeter=0;entryX=0.5;entryY=0;entryPerimeter=0;" edge="1" source="4" target="5" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="12" value="5 fetch retries&amp;#10;exhausted (Gap 1)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#f87171;strokeWidth=2;fontColor=#f87171;fontSize=10;exitX=0.5;exitY=1;exitPerimeter=0;entryX=0.5;entryY=0;entryPerimeter=0;" edge="1" source="4" target="7" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="13" value="All rows inserted&amp;#10;+ DB commit" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#34d399;strokeWidth=2;fontColor=#34d399;fontSize=10;exitX=0.5;exitY=1;exitPerimeter=0;entryX=0.5;entryY=0;entryPerimeter=0;" edge="1" source="5" target="9" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="14" value="IBM MQ&amp;#10;BackoutThreshold=5 ⑤" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#f472b6;strokeWidth=2;fontColor=#f472b6;fontSize=10;exitX=0.5;exitY=1;exitPerimeter=0;entryX=0.5;entryY=0;entryPerimeter=0;" edge="1" source="5" target="10" parent="1"&gt;&lt;mxGeometry relative="1" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="15" value="KEY INVARIANT — IN_PROGRESS cannot be orphaned:&amp;#10;markInProgress() uses REQUIRES (default) → joins the same @Transactional as row inserts.&amp;#10;If ANY step fails: entire tx rolls back → status reverts to SUBMITTED → IBM MQ redelivers → clean retry.&amp;#10;If REQUIRES_NEW used (BUG ④): IN_PROGRESS commits independently → crash mid-row → stuck forever." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;fontColor=#94a3b8;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="540" width="640" height="85" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="16" value="CORNER CASES" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#38bdf8;fontSize=12;fontStyle=1;" vertex="1" parent="1"&gt;&lt;mxGeometry x="720" y="75" width="870" height="28" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="17" value="Horizontal Scaling — Multiple App Instances" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=2;dashed=1;fontSize=9;fontColor=#34d399;fontStyle=1;verticalAlign=top;;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="720" y="115" width="870" height="140" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="18" value="IBM MQ is point-to-point — each message normally delivered to exactly ONE consumer." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="735" y="145" width="500" height="30" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="19" value="🛡 On redelivery across instances: Atomic UPDATE WHERE SUBMITTED ensures only one instance can own a file. DB row lock guarantees mutual exclusion." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;dashed=1;fontColor=#34d399;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="735" y="180" width="840" height="40" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="20" value="🛡 UNIQUE(file_id, row_number) prevents any duplicate row creation even if two instances somehow process simultaneously." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;dashed=1;fontColor=#34d399;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="735" y="225" width="840" height="25" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="21" value="App Crash Scenarios" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#120818;strokeColor=#c084fc;strokeWidth=2;dashed=1;fontSize=9;fontColor=#c084fc;fontStyle=1;verticalAlign=top;;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="720" y="275" width="870" height="210" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="22" value="Crash Before jmsTemplate.send()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#34d399;strokeWidth=1;fontColor=#34d399;fontSize=10;fontStyle=1;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="730" y="305" width="330" height="38" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="23" value="DB: Rolled back&amp;#10;MQ: No message → ✅ Clean. No orphan." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="1070" y="305" width="505" height="38" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="24" value="Crash After send(), before JPA commit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#fb923c;strokeWidth=1;fontColor=#fb923c;fontSize=10;fontStyle=1;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="730" y="349" width="330" height="38" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="25" value="DB: Rolled back&amp;#10;MQ: Message in MQ → ⚠ Gap 1 → fetch retries → DLQ" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="1070" y="349" width="505" height="38" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="26" value="Crash Mid-row insert (tx open)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#34d399;strokeWidth=1;fontColor=#34d399;fontSize=10;fontStyle=1;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="730" y="393" width="330" height="38" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="27" value="DB: Rolled back → SUBMITTED&amp;#10;MQ: Redelivered → ✅ Fresh retry. UNIQUE skips done rows." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="1070" y="393" width="505" height="38" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="28" value="Crash After processFile commits, before ACK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1424;strokeColor=#34d399;strokeWidth=1;fontColor=#34d399;fontSize=10;fontStyle=1;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="730" y="437" width="330" height="38" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="29" value="DB: COMPLETED persisted&amp;#10;MQ: Redelivered → ✅ markInProgress=0 → skip → ACK" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#94a3b8;fontSize=10;" vertex="1" parent="1"&gt;&lt;mxGeometry x="1070" y="437" width="505" height="38" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="30" value="CLIENT_ACKNOWLEDGE Bulk-ACK Risk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#120818;strokeColor=#c084fc;strokeWidth=2;dashed=1;fontSize=9;fontColor=#c084fc;fontStyle=1;verticalAlign=top;;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="720" y="505" width="870" height="100" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="31" value="⚠ JMS spec: acknowledge() on message N acks ALL messages in that session up to N." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=1;dashed=1;fontColor=#f87171;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="730" y="535" width="430" height="32" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="32" value="🛡 factory.setMaxMessagesPerTask(1) — one message per session, one ACK per message." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;dashed=1;fontColor=#34d399;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="730" y="572" width="430" height="28" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="33" value="⚠ IBM MQ session timeout during long processing → redelivered to another instance while first still running." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=1;dashed=1;fontColor=#f87171;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="1170" y="535" width="400" height="32" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="34" value="🛡 Atomic lock + UNIQUE key handles the race. Set HBINT &amp;gt; max processing time or use chunked batches." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;dashed=1;fontColor=#34d399;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="1170" y="572" width="400" height="28" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="35" value="Large File Handling — Chunked Processing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#181008;strokeColor=#fbbf24;strokeWidth=2;dashed=1;fontSize=9;fontColor=#fbbf24;fontStyle=1;verticalAlign=top;;verticalAlign=top;" vertex="1" parent="1"&gt;&lt;mxGeometry x="720" y="625" width="870" height="110" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="36" value="⚠ 100k rows in single @Transactional → DB connection timeout, lock escalation, OOM loading all rows into memory." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=1;dashed=1;fontColor=#f87171;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="730" y="655" width="850" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="37" value="🛡 Chunk 500 rows/batch. Each batch in @Transactional(REQUIRES_NEW). Track last_processed_row in trade_file. On redelivery → skip batches below checkpoint. UNIQUE(file_id, row_num) covers any overlap." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071810;strokeColor=#34d399;strokeWidth=1;dashed=1;fontColor=#34d399;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="730" y="695" width="850" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;/root&gt;&lt;/mxGraphModel&gt;</diagram><diagram id="4._Failure_Matrix" name="4. Failure Matrix">&lt;mxGraphModel background="#1a1f2e" dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0"&gt;&lt;root&gt;&lt;mxCell id="0" /&gt;&lt;mxCell id="1" parent="0" /&gt;&lt;mxCell id="2" value="Trade File Architecture — Complete Failure Matrix (18 Scenarios)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#38bdf8;fontSize=18;fontStyle=3;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="20" width="1100" height="40" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="3" value="Rows 14–16 are implementation BUGS (not runtime failures). They only occur if code is written incorrectly. ②③④ show where each is prevented." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#180707;strokeColor=#f87171;strokeWidth=1;dashed=1;fontColor=#f87171;fontSize=10;align=left;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="68" width="1260" height="32" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="4" value="#" style="whiteSpace=wrap;html=1;fillColor=#0f1e35;strokeColor=#38bdf8;fontColor=#38bdf8;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1"&gt;&lt;mxGeometry x="40" y="115" width="50" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="5" value="Failure Scenario" style="whiteSpace=wrap;html=1;fillColor=#0f1e35;strokeColor=#38bdf8;fontColor=#38bdf8;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1"&gt;&lt;mxGeometry x="100" y="115" width="420" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="6" value="DB State" style="whiteSpace=wrap;html=1;fillColor=#0f1e35;strokeColor=#38bdf8;fontColor=#38bdf8;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1"&gt;&lt;mxGeometry x="530" y="115" width="190" height="35" as="geometry" /&gt;&lt;/mxCell&gt;&lt;mxCell id="7" value="MQ State" style="whiteSpace=wrap;html=1;fillColor=#0f1e35;strokeColor=#38bdf8;fontColor=#38bdf8;fontSize=10;fontStyle=1;align=center;" vertex=